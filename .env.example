# =========================================================================
#  Galeria ślubna — konfiguracja środowiska
#  Skopiuj do `.env` i uzupełnij. NIE commituj pliku `.env`.
# =========================================================================

# --- Aplikacja / adres publiczny ---
# Pełny URL pod którym stoi galeria (używany w meta i przez generator QR).
PUBLIC_BASE_URL=https://wesele.moneylet.pl
# Port procesu Node (za Nginx). Musi zgadzać się z ecosystem.config.cjs i Nginx.
PORT=3100
NODE_ENV=production

# --- Teksty na stronie ---
EVENT_TITLE=Aleksandra & Jakub
EVENT_SUBTITLE=Podziel się z nami swoimi wspomnieniami z tego dnia

# --- Baza danych (SQLite — tylko metadane) ---
DATABASE_PATH=./data/gallery.sqlite
TMP_DIR=./data/tmp

# --- Panel administratora ---
# Wygeneruj: npm run hash-password -- "twoje-haslo"
ADMIN_PASSWORD_HASH=
# Sekret do podpisu ciasteczka sesji (losowy hex). Generuje się razem z hasłem,
# lub: openssl rand -hex 32
ADMIN_SESSION_SECRET=
ADMIN_SESSION_HOURS=12

# Sól do haszowania IP (anti-abuse). Ustaw dowolny losowy ciąg.
IP_HASH_SALT=zmien-mnie-na-cos-losowego

# --- Cloudflare R2 (storage plików, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wesele-galeria
# Zwykle zostaw puste — endpoint wyliczy się z R2_ACCOUNT_ID.
# Jawnie: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Opcjonalnie, ale ZALECANE dla szybkości: publiczny adres bucketu (r2.dev lub
# własna domena). Gdy ustawiony, miniatury i plakaty lecą prosto z R2/Cloudflare
# (z pominięciem VPS) i są cache'owane. Włącz w R2: Settings → Public access →
# r2.dev, i wklej tu ten adres (np. https://pub-xxxx.r2.dev). Puste = miniatury
# serwowane przez VPS (też cache'owane, ale obciążają serwer przy pierwszym ładowaniu).
R2_PUBLIC_BASE=

# --- Limity uploadu ---
MAX_IMAGE_MB=50
MAX_VIDEO_MB=500
# Rozmiar części multipart (min 5 MiB dla R2, poza ostatnią częścią).
UPLOAD_PART_MB=10

# --- Rate limiting ---
RL_PRESIGN_MAX=60
RL_PRESIGN_WINDOW_SEC=600
RL_LOGIN_MAX=10
RL_LOGIN_WINDOW_SEC=600

# --- Binaria (opcjonalne — jeśli nie w PATH) ---
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
