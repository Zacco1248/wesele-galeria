  "description": "Wspólna galeria ślubna — goście wrzucają zdjęcia i filmy przez QR. SvelteKit + Cloudflare R2.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
