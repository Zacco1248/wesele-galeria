    "vite": "^6.2.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fontsource/cormorant-garamond": "^5.3.0",
    "@fontsource/mulish": "^5.3.0",
    "@types/archiver": "^6.0.3",
    "archiver": "^7.0.1",
